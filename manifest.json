{
  "manifest_version": 3,
  "name": "JSON Beauty",
  "version": "1.0.0",
  "description": "Paste, format, and browse your JSON history with a clean viewer.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"]
}
